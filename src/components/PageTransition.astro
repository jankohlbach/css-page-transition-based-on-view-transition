<script>
  // import { scrollStart, scrollStop } from '../scripts/scroll';

  window.addEventListener('pageswap', async (e) => {
    if (!e.viewTransition) return;
    // scrollStop();
    sessionStorage.setItem('pt:active', 'true');
  });

  window.addEventListener('pt:done', () => {
    // scrollStart();
    window.dispatchEvent(new Event('inview:trigger-manual'));
  });
</script>

<div class="pt pt-1"></div>
<div class="pt pt-2"></div>

<style lang="scss">
  .pt {
    position: fixed;
    inset: 0;
    left: -100vw;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .pt-1 {
    background-color: salmon;
    view-transition-name: pt-1;
  }

  .pt-2 {
    background-color: tomato;
    view-transition-name: pt-2;
  }
</style>
